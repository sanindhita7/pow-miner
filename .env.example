# ─── POW Miner Configuration ───────────────────────────
# Comma-separated Solana wallet addresses for multi-wallet mining
WALLETS=YourWalletAddress1,YourWalletAddress2

# Mining server URL
SERVER_URL=https://mine.powsolmeme.com

# Number of worker threads (default: auto-detect CPU cores)
THREADS=4

# Log file path (optional)
LOG_FILE=logs/pow-miner.log

# Enable debug output
# DEBUG=true
